# Примеры cron-расписания для reflection
# Установка: crontab -e  (добавьте нужную строку)
#
# Формат: минута  час  день  месяц  день_недели  команда
# ─────────────────────────────────────────────────────────

# ── Локальный запуск (uv) ────────────────────────────────────────────────

# Каждый час
0 * * * * cd /opt/reflection && uv run reflection --config config.yaml >> /var/log/reflection.log 2>&1

# Каждые 30 минут
*/30 * * * * cd /opt/reflection && uv run reflection --config config.yaml >> /var/log/reflection.log 2>&1

# Каждую ночь в 03:00
0 3 * * * cd /opt/reflection && uv run reflection --config config.yaml >> /var/log/reflection.log 2>&1


# ── Docker (однократный профиль) ─────────────────────────────────────────

# Каждый час через docker compose
0 * * * * cd /opt/reflection && docker compose run --rm mirror-once >> /var/log/reflection.log 2>&1

# Каждый час через docker run (образ уже собран)
0 * * * * docker run --rm \
  -v /opt/reflection/config.yaml:/app/config.yaml:ro \
  -v reflection_mirrors:/mirrors \
  -v /opt/reflection/keys:/keys:ro \
  reflection:latest >> /var/log/reflection.log 2>&1
